{
  "info": {
    "_postman_id": "bc7a7e1a-3e08-42f1-9b7a-c05d21f03f73",
    "name": "Bank Application - Microservicios (Client / Account)",
    "description": "Colección para probar client-service (8001) y account-service (8000). Ejecutar primero 'Auth > Login (cliente demo)' para capturar el token automáticamente; luego 'Clients > Crear cliente', 'Accounts > Crear cuenta' y 'Transactions > Crear depósito' encadenan sus ids solos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "16727589"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (cliente demo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.data.token);",
                  "pm.test('Login OK y token recibido', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(json.data.token).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dni\": \"0000000000\",\n  \"password\": \"Demo1234\"\n}"
            },
            "url": {
              "raw": "{{clientBaseUrl}}/api/auth/login",
              "host": [
                "{{clientBaseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
